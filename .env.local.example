# ─────────────────────────────────────────────────────────────────────────────
# SANITY — get these from https://sanity.io/manage → your project
# ─────────────────────────────────────────────────────────────────────────────

# Found in: sanity.io/manage → your project → API → Project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Almost always "production" unless you created a different dataset
NEXT_PUBLIC_SANITY_DATASET=production

# Found in: sanity.io/manage → your project → API → Tokens → Add API token
# Permission needed: Editor (for the import script)
# ⚠️  NEVER commit this to GitHub — it has write access
SANITY_API_TOKEN=your_write_token_here

# ─────────────────────────────────────────────────────────────────────────────
# SITE — used for canonical URLs in <head> (SEO)
# ─────────────────────────────────────────────────────────────────────────────

# Your production domain, NO trailing slash.
# Example: https://www.shrirangmukta.com
# Used by generateMetadata() in app/layout.tsx to build absolute canonical URLs.
# Leave empty in development (defaults to http://localhost:3000).
NEXT_PUBLIC_SITE_URL=https://your-domain-here.com
